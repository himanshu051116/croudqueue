# PostgreSQL 17 / Redis local development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_DB=crowdcue
DATABASE_URL=postgresql+psycopg://postgres:change-this-local-password@localhost:54321/crowdcue
DATABASE_POOL_SIZE=2
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=300
REDIS_URL=redis://localhost:63791/0
REDIS_REQUIRED=false

# Gemini is optional. Without a key, CrowdCue uses deterministic fallback and
# reports the provenance honestly.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_REVISION=2026-05-20
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=3
GEMINI_REQUEST_DELAY_SECONDS=0
GEMINI_SCENARIO_COOLDOWN_SECONDS=2

# Demo-only fault injection. Keep false outside the controlled demonstration.
ENABLE_DEMO_FAULT_INJECTION=false

# Generate a strong value before any public deployment.
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ENVIRONMENT=development
LOG_LEVEL=INFO
